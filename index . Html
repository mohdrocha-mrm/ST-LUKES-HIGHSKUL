<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Secondary School Management System</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      background:#f4f6f9;
      color:#333;
    }

    header{
      background:#0d47a1;
      color:white;
      padding:20px;
      text-align:center;
      font-size:28px;
      font-weight:bold;
    }

    .container{
      display:flex;
      min-height:100vh;
    }

    .sidebar{
      width:250px;
      background:#1e293b;
      color:white;
      padding:20px;
    }

    .sidebar h2{
      margin-bottom:20px;
      text-align:center;
    }

    .sidebar ul{
      list-style:none;
    }

    .sidebar ul li{
      padding:15px;
      margin:10px 0;
      background:#334155;
      border-radius:8px;
      cursor:pointer;
      transition:0.3s;
    }

    .sidebar ul li:hover{
      background:#2563eb;
    }

    .main{
      flex:1;
      padding:20px;
    }

    .dashboard{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:20px;
      margin-bottom:30px;
    }

    .card{
      background:white;
      padding:20px;
      border-radius:12px;
      box-shadow:0 2px 8px rgba(0,0,0,0.1);
      text-align:center;
    }

    .card h3{
      margin-bottom:10px;
      color:#0d47a1;
    }

    .section{
      background:white;
      padding:20px;
      border-radius:12px;
      box-shadow:0 2px 8px rgba(0,0,0,0.1);
      margin-bottom:30px;
    }

    table{
      width:100%;
      border-collapse:collapse;
      margin-top:15px;
    }

    table th, table td{
      border:1px solid #ddd;
      padding:12px;
      text-align:left;
    }

    table th{
      background:#0d47a1;
      color:white;
    }

    form{
      margin-top:20px;
    }

    form input{
      width:100%;
      padding:12px;
      margin:10px 0;
      border:1px solid #ccc;
      border-radius:8px;
    }

    button{
      background:#0d47a1;
      color:white;
      border:none;
      padding:12px 20px;
      border-radius:8px;
      cursor:pointer;
      transition:0.3s;
    }

    button:hover{
      background:#1565c0;
    }

    footer{
      text-align:center;
      padding:15px;
      background:#0d47a1;
      color:white;
    }
  </style>
</head>

<body>

<header>
  Secondary School Management System
</header>

<div class="container">

  <div class="sidebar">
    <h2>MENU</h2>

    <ul>
      <li onclick="showSection('students')">Student Management</li>
      <li onclick="showSection('teachers')">Teacher Management</li>
      <li onclick="showSection('fees')">Fee Management</li>
    </ul>
  </div>

  <div class="main">

    <!-- DASHBOARD -->
    <div class="dashboard">
      <div class="card">
        <h3>Total Students</h3>
        <p id="studentCount">3</p>
      </div>

      <div class="card">
        <h3>Total Teachers</h3>
        <p id="teacherCount">2</p>
      </div>

      <div class="card">
        <h3>Fee Collected</h3>
        <p>KES 120,000</p>
      </div>
    </div>

    <!-- STUDENTS -->
    <div class="section" id="students">
      <h2>Student Management</h2>

      <table id="studentTable">
        <tr>
          <th>Name</th>
          <th>Class</th>
          <th>Admission No</th>
        </tr>

        <tr>
          <td>Mohammed Ali</td>
          <td>Form 3</td>
          <td>ADM001</td>
        </tr>

        <tr>
          <td>Aisha Hassan</td>
          <td>Form 2</td>
          <td>ADM002</td>
        </tr>

        <tr>
          <td>John Kamau</td>
          <td>Form 4</td>
          <td>ADM003</td>
        </tr>
      </table>

      <form onsubmit="addStudent(event)">
        <input type="text" id="studentName" placeholder="Student Name" required>
        <input type="text" id="studentClass" placeholder="Class" required>
        <input type="text" id="studentAdm" placeholder="Admission Number" required>

        <button type="submit">Add Student</button>
      </form>
    </div>

    <!-- TEACHERS -->
    <div class="section" id="teachers" style="display:none;">
      <h2>Teacher Management</h2>

      <table id="teacherTable">
        <tr>
          <th>Name</th>
          <th>Subject</th>
        </tr>

        <tr>
          <td>Mr. Otieno</td>
          <td>Mathematics</td>
        </tr>

        <tr>
          <td>Mrs. Fatuma</td>
          <td>Biology</td>
        </tr>
      </table>

      <form onsubmit="addTeacher(event)">
        <input type="text" id="teacherName" placeholder="Teacher Name" required>
        <input type="text" id="teacherSubject" placeholder="Subject" required>

        <button type="submit">Add Teacher</button>
      </form>
    </div>

    <!-- FEES -->
    <div class="section" id="fees" style="display:none;">
      <h2>Fee Management</h2>

      <table id="feeTable">
        <tr>
          <th>Student</th>
          <th>Amount Paid</th>
          <th>Balance</th>
        </tr>

        <tr>
          <td>Mohammed Ali</td>
          <td>KES 40,000</td>
          <td>KES 10,000</td>
        </tr>

        <tr>
          <td>Aisha Hassan</td>
          <td>KES 35,000</td>
          <td>KES 15,000</td>
        </tr>
      </table>

      <form onsubmit="addFee(event)">
        <input type="text" id="feeStudent" placeholder="Student Name" required>
        <input type="number" id="feePaid" placeholder="Amount Paid" required>
        <input type="number" id="feeBalance" placeholder="Balance" required>

        <button type="submit">Add Fee Record</button>
      </form>
    </div>

  </div>
</div>

<footer>
  © 2026 Secondary School Management System
</footer>

<script>

  function showSection(sectionId){

    document.getElementById('students').style.display = 'none';
    document.getElementById('teachers').style.display = 'none';
    document.getElementById('fees').style.display = 'none';

    document.getElementById(sectionId).style.display = 'block';
  }

  // ADD STUDENT
  function addStudent(event){
    event.preventDefault();

    let name = document.getElementById('studentName').value;
    let className = document.getElementById('studentClass').value;
    let adm = document.getElementById('studentAdm').value;

    let table = document.getElementById('studentTable');

    let row = table.insertRow();

    row.insertCell(0).innerHTML = name;
    row.insertCell(1).innerHTML = className;
    row.insertCell(2).innerHTML = adm;

    let count = document.getElementById('studentCount');
    count.innerHTML = parseInt(count.innerHTML) + 1;

    event.target.reset();
  }

  // ADD TEACHER
  function addTeacher(event){
    event.preventDefault();

    let name = document.getElementById('teacherName').value;
    let subject = document.getElementById('teacherSubject').value;

    let table = document.getElementById('teacherTable');

    let row = table.insertRow();

    row.insertCell(0).innerHTML = name;
    row.insertCell(1).innerHTML = subject;

    let count = document.getElementById('teacherCount');
    count.innerHTML = parseInt(count.innerHTML) + 1;

    event.target.reset();
  }

  // ADD FEES
  function addFee(event){
    event.preventDefault();

    let student = document.getElementById('feeStudent').value;
    let paid = document.getElementById('feePaid').value;
    let balance = document.getElementById('feeBalance').value;

    let table = document.getElementById('feeTable');

    let row = table.insertRow();

    row.insertCell(0).innerHTML = student;
    row.insertCell(1).innerHTML = "KES " + paid;
    row.insertCell(2).innerHTML = "KES " + balance;

    event.target.reset();
  }

</script>

</body>
</html>
